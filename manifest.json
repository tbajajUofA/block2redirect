{
  "manifest_version": 3,
  "name": "Block2Redirect",
  "version": "1.0",
  "description": "Redirect distracting sites to productive ones.",
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html"
  }
}


